<span class="message-success" style="display: none"><%=locals.messages.success%></span>
<span class="message-error" style="display: none"><%=locals.messages.error%></span>
<main>
  <h2><a href="/panel/robot/">ربات</a></h2>

  <input type="search" placeholder="جستجو..." name="" class="search-input" />
  <div class="container-products">
    <div class="product-table">
      <table>
        <thead>
          <tr>
            <th>تصویر</th>
            <th>عنوان</th>
            <th>کاهش</th>
            <th>کمترین</th>
            <th>بیشترین</th>
            <th>ربات</th>
            <th>بای باکس</th>
            <th>افزایش</th>
            <th></th>
          </tr>
        </thead>
        <tbody class="tbody-product">
          <%response.products.forEach(product => {%>
          <tr>
            <td><img src="<%-product.img%>" alt="" /></td>
            <td>
              <a href="https://www.digikala.com/product/dkp-<%-product.dkp%>" target="_blank"
                ><h3 class="h3-robot"><%-product.title%></h3></a
              >
            </td>

            <td>
              <input id="input-reduce-price" class="input-number" type="number" value="<%-product?.robot?.reducePrice%>" />
            </td>
            <td>
              <input id="input-min-price" class="input-number" type="number" value="<%-product?.robot?.minPrice%>" />
            </td>
            <td>
              <input id="input-max-price" class="input-number" type="number" value="<%-product?.robot?.maxPrice%>" />
            </td>

            <td>
              <label class="switch">
                <input id="switch-is-active" type="checkbox" <%-product?.robot?.isActive ? "checked" : "" %> />
                <span class="slider round"></span>
              </label>
            </td>
            <td>
              <label class="switch">
                <input id="switch-is-buybox" type="checkbox" <%-product?.robot?.isBuyBox ? "checked" : "" %> />
                <span class="slider round"></span>
              </label>
            </td>
            <td>
              <label class="switch">
                <input id="switch-is-checkprice" type="checkbox" <%-product?.robot?.isCheckPrice ? "checked" : "" %> />
                <span class="slider round"></span>
              </label>
            </td>

            <td>
              <button class="btn success" onclick="btnSaveRobot(event ,'<%-product.id%>')" id="btn-save">ثبت</button>
            </td>
            <% }) %>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
  <div class="pagination">
    <a href="#">&laquo;</a>

    <%for(let i = 1; response.pages >= i ; i++) {%> <% if(i== response.page) { %>
    <a class="active" href="/panel/robot/?page=<%-i%>"><%-i%></a>
    <% } else {%>
    <a href="/panel/robot/?page=<%-i%>"><%-i%></a>
    <% } %> <% } %>

    <a href="#">&raquo;</a>
  </div>
</main>

<script src="/scripts/pages/panel/robot.js"></script>
