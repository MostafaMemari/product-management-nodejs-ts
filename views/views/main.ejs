<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles/style.css" />
    <link rel="stylesheet" href="/styles/main.css" />
    <title>Document</title>
  </head>
  <body>
    <div id="modal-sell-buy" class="modal">
      <div class="modal-content">
        <div class="modal-header">
          <h2></h2>
          <span class="close">&times;</span>
        </div>
        <div class="modal-body">
          <div class="report-product-container">
            <div class="card-date-container"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="container">
      <%-include("./partials/_aside")%>

      <main>
        <h2 class="title-buy-box"></h2>
        <div class="buy-box-container"></div>
        <h2>آخرین تغییرات</h2>
        <div class="seach-container">
          <input type="search" placeholder="جستجو..." name="" class="search-input-robot" />
          <input type="search" placeholder="جستجو..." name="" class="search-input" />
          <select id="seller-select-box" name="seller">
            <option value="none" selected>انتخاب فروشنده</option>
            <%sellers.forEach(seller => {%>
            <option value="<%=seller.sellerID%>"><%=seller.sellerTitle%></option>
            <%})%>
          </select>
          <button id="btn-referesh" class="btn success">بروزرسانی</button>
        </div>
        <div class="container-products">
          <div class="product-table">
            <table>
              <thead>
                <tr>
                  <th>عنوان محصول</th>
                  <th>فروشنده</th>
                  <th>قیمت</th>
                  <th>ساعت</th>
                  <th>تاریخ</th>
                  <th>وضعیت</th>
                </tr>
              </thead>
              <tbody class="tbody-product"></tbody>
            </table>
          </div>
        </div>
        <div class="pagination-container"></div>
      </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://kit.fontawesome.com/7f969f3a77.js" crossorigin="anonymous"></script>
    <script src="/scripts/index.js"></script>
    <script src="/scripts/main.js"></script>
  </body>
</html>
